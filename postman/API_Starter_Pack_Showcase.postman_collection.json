						},
						{
							"name": "401 — Token already used (replay attack)",
							"originalRequest": {
								"method": "POST",
								"header": [
									{ "key": "Content-Type", "value": "application/json" }
								],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"refreshToken\": \"already-used-token\"\n}"
								},
								"url": {
									"raw": "{{baseUrl}}/auth/refresh",
									"host": ["{{baseUrl}}"],
									"path": ["auth", "refresh"]
								}
							},
							"status": "Unauthorized",
							"code": 401,
							"_postman_previewlanguage": "json",
							"header": [
								{ "key": "Content-Type", "value": "application/json" }
							],
							"body": "{\n    \"status\": 401,\n    \"message\": \"Refresh token has been revoked\",\n    \"timestamp\": \"2026-03-25T14:30:20.000000\"\n}"
						}
