								"exec": [
									"pm.test(\"Logged out — tokens revoked and cleared\", function () {",
									"    pm.response.to.have.status(204);",
									"    pm.collectionVariables.set(\"token\", \"\");",
									"    pm.collectionVariables.set(\"refreshToken\", \"\");",
									"});"
								]
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"refreshToken\": \"{{refreshToken}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/logout",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "logout"]
						},
						"description": "Revoke the current refresh token and end the session.\n\nThe refresh token is invalidated in the database. The `{{token}}` and `{{refreshToken}}` variables are cleared."
					},
					"response": [
