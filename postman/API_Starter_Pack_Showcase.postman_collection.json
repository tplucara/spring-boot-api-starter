		{
			"name": "3. Token Rotation",
			"item": [
				{
					"name": "Refresh Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test(\"Tokens rotated — new pair saved\", function () {",
									"    pm.response.to.have.status(200);",
									"    const body = pm.response.json();",
									"    pm.expect(body.accessToken).to.be.a(\"string\");",
									"    pm.expect(body.refreshToken).to.be.a(\"string\");",
									"    pm.collectionVariables.set(\"token\", body.accessToken);",
									"    pm.collectionVariables.set(\"refreshToken\", body.refreshToken);",
									"    const payload = JSON.parse(atob(body.accessToken.split('.')[1]));",
									"    pm.collectionVariables.set(\"userId\", payload.sub);",
									"});"
								]
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"refreshToken\": \"{{refreshToken}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/refresh",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "refresh"]
						},
						"description": "Exchange a valid refresh token for a new token pair.\n\n**Token Rotation:** the previous refresh token is immediately revoked. A new access token and refresh token are issued and saved automatically.\n\nThis prevents replay attacks — each refresh token can only be used once."
					},
					"response": [
						{
							"name": "200 — Tokens rotated",
							"originalRequest": {
								"method": "POST",
								"header": [
									{ "key": "Content-Type", "value": "application/json" }
								],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"refreshToken\": \"{{refreshToken}}\"\n}"
								},
								"url": {
									"raw": "{{baseUrl}}/auth/refresh",
									"host": ["{{baseUrl}}"],
									"path": ["auth", "refresh"]
								}
							},
							"status": "OK",
