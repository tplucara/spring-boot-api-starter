								{ "key": "Content-Type", "value": "application/json" }
							],
							"body": "{\n    \"id\": \"a1b2c3d4-e5f6-7890-abcd-ef1234567890\",\n    \"email\": \"admin@example.com\",\n    \"active\": true,\n    \"createdAt\": \"2026-03-25T14:30:00.000000\"\n}"
						}
					]
				}
			],
			"description": "**Validate JWT refresh token rotation.**\n\nDemonstrates the security model: each refresh token is single-use. After rotation, the old token is revoked and a new pair is issued."
		},
